            <div class="logo-area">
                <img src="~/ImagenDefault/StorePan.png" alt="Logo Mi Tienda">
                <h1>Bienvenido</h1>
                <p>Inicia sesión para continuar</p>
            </div>

            <!-- Formulario -->
            <div class="form-body">
                <form asp-controller="Acceso" asp-action="Login" method="post" novalidate>

                    <div class="field-group">
                        <label class="field-label" for="Correo">Correo electrónico</label>
                        <div class="field-wrap">
                            <i class="fas fa-envelope field-icon"></i>
                            <input id="Correo"
                                   type="email"
                                   class="field-input"
                                   placeholder="tucorreo@ejemplo.com"
                                   asp-for="Correo"
                                   autocomplete="email"
                                   inputmode="email">
                        </div>
                    </div>

                    <div class="field-group">
                        <label class="field-label" for="Clave">Contraseña</label>
                        <div class="field-wrap">
                            <i class="fas fa-lock field-icon"></i>
                            <input id="Clave"
                                   type="password"
                                   class="field-input"
                                   placeholder="••••••••"
                                   asp-for="Clave"
                                   autocomplete="current-password">
                        </div>
                    </div>

                    <div class="check-group">
                        <input type="checkbox" id="chkMantenerSesion" asp-for="MantenerSesion">
                        <label for="chkMantenerSesion">Mantener sesión iniciada</label>
                    </div>

                    @if (ViewData["Mensaje"] != null)
                    {
                        <div class="alert-danger" role="alert">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>@ViewData["Mensaje"]</span>
                        </div>
                    }

                    <button type="submit" class="btn-submit">
                        Ingresar
                    </button>

                </form>

                <div class="divider">o</div>

                <div class="links-area">
                    <a class="link-item" href="@Url.Action("RestablecerClave", "Acceso")">
                        ¿Olvidó su contraseña?
                    </a>
                    <a class="link-register" href="@Url.Action("Registrarse", "Acceso")">
                        Crear una cuenta
                    </a>
                </div>
            </div>

        </div>
    </div>
</body>

</html>
