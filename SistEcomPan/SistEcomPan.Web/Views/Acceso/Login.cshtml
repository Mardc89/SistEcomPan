@model SistEcomPan.Web.Models.ViewModels.VMUsuarioLogin;

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">

<head>

    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Mi Tienda - Login</title>

    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="~/css/sb-admin-2.css" rel="stylesheet">

    <style>

        body {
            background: linear-gradient(135deg,#36b9cc,#1cc88a);
        }

        .login-card {
            border-radius: 12px;
        }

        .login-card .form-control {
            border-radius: 30px;
            padding: 12px 15px;
        }

        .login-card .btn {
            border-radius: 30px;
            padding: 10px;
        }

        .login-image {
       /*      background: url('/img/login.jpg'); */
            background-size: cover;
            background-position: center;
        }
/* 
        @@media (max-width:768px){

            .login-image{
                display:none;
            }

        } */

        @@media (max-width: 576px) {

            .card {
                border-radius: 0;
                box-shadow: none;
            }

            body {
                background: white;
            }

    </style>

</head>

<body>

    <div class="container">

        <div class="row justify-content-center align-items-center min-vh-100">

            <div class="col-12 col-md-8 col-lg-10 col-xl-8">

                <div class="card shadow-lg login-card">

                    <div class="row g-0">

                        <div class="col-md-6 d-none d-lg-block login-image"></div>

                        <div class="col-md-6">

                            <div class="card-body p-4">

                                <div class="text-center mb-4">
                                    <h4 class="text-gray-900">Bienvenido</h4>
                                    <p class="small text-muted">Ingrese a su cuenta</p>
                                </div>

                                <form asp-controller="Acceso" asp-action="Login" method="post">

                                    <div class="form-group mb-3">
                                        <div class="input-group">

                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fas fa-envelope"></i>
                                                </span>
                                            </div>

                                            <input type="email"
                                                   class="form-control"
                                                   placeholder="Correo"
                                                   asp-for="Correo">

                                        </div>
                                    </div>

                                    <div class="form-group mb-3">

                                        <div class="input-group">

                                            <div class="input-group-prepend">
                                                <span class="input-group-text">
                                                    <i class="fas fa-lock"></i>
                                                </span>
                                            </div>

                                            <input type="password"
                                                   class="form-control"
                                                   placeholder="Contraseña"
                                                   asp-for="Clave">

                                        </div>

                                    </div>

                                    <div class="form-group mb-3">

                                        <div class="custom-control custom-checkbox small">

                                            <input type="checkbox"
                                                   class="custom-control-input"
                                                   id="chkMantenerSesion"
                                                   asp-for="MantenerSesion">

                                            <label class="custom-control-label"
                                                   for="chkMantenerSesion">

                                                Mantener sesión

                                            </label>

                                        </div>

                                    </div>

                                    @if (ViewData["Mensaje"] != null)
                                    {
                                        <div class="alert alert-danger">
                                            @ViewData["Mensaje"]
                                        </div>
                                    }

                                    <button type="submit"
                                            class="btn btn-primary btn-block">

                                        Ingresar

                                    </button>

                                </form>

                                <hr>

                                <div class="text-center">

                                    <a class="small d-block"
                                       href="@Url.Action("RestablecerClave", "Acceso")">

                                        ¿Olvidó su contraseña?

                                    </a>

                                    <a class="small d-block mt-2"
                                       href="@Url.Action("Registrarse", "Acceso")">

                                        Crear cuenta

                                    </a>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>









