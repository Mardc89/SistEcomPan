@* @model SistEcomPan.Web.Models.ViewModels.VMUsuarioLogin;

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ES">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Mi Tienda - Login</title>

    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css">
    <link href="~/css/sb-admin-2.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --brand:       #1a56db;
            --brand-dark:  #1340b0;
            --surface:     #ffffff;
            --muted:       #6b7280;
            --border:      #e5e7eb;
            --danger:      #ef4444;
            --radius:      14px;
            --shadow:      0 20px 60px rgba(0,0,0,.12);
        }

        html, body {
            height: 100%;
            font-family: 'DM Sans', sans-serif;
            background: linear-gradient(135deg, #1a56db 0%, #0f3a96 50%, #071d6a 100%);
            min-height: 100vh;
        }

        /* ── Page shell ── */
        .page-shell {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
        }

        /* ── Brand badge (visible on mobile only) ── */
        .brand-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 28px;
        }

        .brand-icon {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,.18);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(8px);
        }

        .brand-icon svg {
            width: 26px;
            height: 26px;
            fill: #ffffff;
        }

        .brand-name {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem;
            color: #ffffff;
            letter-spacing: .5px;
        }

        /* ── Card ── */
        .login-card {
            width: 100%;
            max-width: 420px;
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            overflow: hidden;
            animation: slideUp .45s cubic-bezier(.22,1,.36,1) both;
        }

        @@keyframes slideUp {
            from { opacity: 0; transform: translateY(28px); }
            to   { opacity: 1; transform: translateY(0);    }
        }

        /* ── Card header strip ── */
        .card-header-strip {
            background: linear-gradient(120deg, #1a56db, #0f3a96);
            padding: 28px 32px 24px;
            text-align: center;
        }

        .card-header-strip h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.55rem;
            color: #ffffff;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .card-header-strip p {
            font-size: .84rem;
            color: rgba(255,255,255,.72);
        }

        /* ── Card body ── */
        .card-body-inner {
            padding: 32px 28px 28px;
        }

        /* ── Form elements ── */
        .field-group {
            margin-bottom: 18px;
        }

        .field-label {
            display: block;
            font-size: .78rem;
            font-weight: 600;
            color: #374151;
            text-transform: uppercase;
            letter-spacing: .06em;
            margin-bottom: 7px;
        }

        .field-wrap {
            position: relative;
        }

        .field-icon {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
            font-size: .9rem;
            pointer-events: none;
            transition: color .2s;
        }

        .field-wrap:focus-within .field-icon {
            color: var(--brand);
        }

        .field-input {
            width: 100%;
            padding: 13px 14px 13px 40px;
            border: 1.5px solid var(--border);
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: .95rem;
            color: #111827;
            background: #f9fafb;
            transition: border-color .2s, box-shadow .2s, background .2s;
            -webkit-appearance: none;
            appearance: none;
        }

        .field-input:focus {
            outline: none;
            border-color: var(--brand);
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(26,86,219,.12);
        }

        /* ── Checkbox ── */
        .check-group {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 22px;
        }

        .check-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--brand);
            cursor: pointer;
            flex-shrink: 0;
            border-radius: 4px;
        }

        .check-group label {
            font-size: .88rem;
            color: #374151;
            cursor: pointer;
            user-select: none;
        }

        /* ── Alert ── */
        .alert-danger {
            background: #fef2f2;
            border: 1px solid #fecaca;
            border-radius: 9px;
            color: var(--danger);
            font-size: .875rem;
            padding: 11px 14px;
            margin-bottom: 18px;
            display: flex;
            align-items: flex-start;
            gap: 8px;
        }

        .alert-danger i {
            margin-top: 2px;
            flex-shrink: 0;
        }

        /* ── Submit button ── */
        .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #1a56db, #1340b0);
            color: #ffffff;
            border: none;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-size: 1rem;
            font-weight: 600;
            letter-spacing: .3px;
            cursor: pointer;
            transition: transform .15s, box-shadow .15s, opacity .15s;
            box-shadow: 0 4px 16px rgba(26,86,219,.35);
        }

        .btn-submit:hover {
            opacity: .92;
            transform: translateY(-1px);
            box-shadow: 0 6px 22px rgba(26,86,219,.45);
        }

        .btn-submit:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(26,86,219,.3);
        }

        /* ── Divider ── */
        .divider {
            display: flex;
            align-items: center;
            gap: 12px;
            margin: 22px 0;
            color: #9ca3af;
            font-size: .8rem;
        }

        .divider::before,
        .divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        /* ── Links ── */
        .links-area {
            display: flex;
            flex-direction: column;
            gap: 12px;
            align-items: center;
        }

        .link-item {
            font-size: .875rem;
            color: var(--brand);
            text-decoration: none;
            font-weight: 500;
            transition: color .15s;
        }

        .link-item:hover {
            color: var(--brand-dark);
            text-decoration: underline;
        }

        .link-register {
            display: inline-block;
            padding: 10px 28px;
            border: 1.5px solid var(--brand);
            border-radius: 10px;
            font-size: .875rem;
            color: var(--brand);
            text-decoration: none;
            font-weight: 600;
            transition: background .15s, color .15s;
        }

        .link-register:hover {
            background: var(--brand);
            color: #ffffff;
        }

        /* ── Desktop: show image panel ── */
        @@media (min-width: 900px) {
            .login-card {
                max-width: 820px;
                display: grid;
                grid-template-columns: 1fr 1fr;
            }

            .card-header-strip { display: none; }

            .image-panel {
                display: block !important;
                background: linear-gradient(160deg, #1a56db 0%, #071d6a 100%);
                position: relative;
                overflow: hidden;
            }

            .image-panel-inner {
                position: absolute;
                inset: 0;
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 40px;
                text-align: center;
            }

            .image-panel-icon {
                width: 72px;
                height: 72px;
                background: rgba(255,255,255,.15);
                border-radius: 20px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0 auto 20px;
                backdrop-filter: blur(6px);
            }

            .image-panel-icon svg {
                width: 38px;
                height: 38px;
                fill: #ffffff;
            }

            .image-panel h2 {
                font-family: 'Playfair Display', serif;
                font-size: 2rem;
                color: #ffffff;
                margin-bottom: 10px;
            }

            .image-panel p {
                font-size: .9rem;
                color: rgba(255,255,255,.68);
                line-height: 1.6;
            }

            /* decorative circles */
            .deco-circle {
                position: absolute;
                border-radius: 50%;
                background: rgba(255,255,255,.06);
            }

            .deco-circle.a { width: 260px; height: 260px; bottom: -80px; left: -80px; }
            .deco-circle.b { width: 160px; height: 160px; top: -40px; right: -40px; }
        }

        .image-panel { display: none; }

        /* ── Safe area for notched phones ── */
        @@supports (padding-bottom: env(safe-area-inset-bottom)) {
            .page-shell {
                padding-bottom: calc(24px + env(safe-area-inset-bottom));
            }
        }
    </style>
</head>

<body>
    <div class="page-shell">

        <!-- Brand badge (mobile) -->
        <div class="brand-badge">
            <div class="brand-icon">
                <!-- shopping-bag icon -->
                <svg viewBox="0 0 24 24" xmlns="">
                    <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3.5 6h17M16 10a4 4 0 0 1-8 0"/>
                </svg>
            </div>
            <span class="brand-name">Mi Tienda</span>
        </div>

        <div class="login-card">

            <!-- Image panel (desktop left column) -->
            <div class="image-panel">
                <div class="deco-circle a"></div>
                <div class="deco-circle b"></div>
                <div class="image-panel-inner">
                    <div class="image-panel-icon">
                        <svg viewBox="0 0 24 24" xmlns="">
                            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4zM3.5 6h17M16 10a4 4 0 0 1-8 0"/>
                        </svg>
                    </div>
                    <h2>Bienvenido de vuelta</h2>
                    <p>Accede a tu cuenta y descubre las mejores ofertas de nuestra tienda.</p>
                </div>
            </div>

            <!-- Form column -->
            <div>
                <!-- Header strip (mobile) -->
                <div class="card-header-strip">
                    <h1>Bienvenido</h1>
                    <p>Inicia sesión para continuar</p>
                </div>

                <div class="card-body-inner">
                    <form asp-controller="Acceso" asp-action="Login" method="post" novalidate>

                        <div class="field-group">
                            <label class="field-label" for="Correo">Correo electrónico</label>
                            <div class="field-wrap">
                                <i class="fas fa-envelope field-icon"></i>
                                <input id="Correo"
                                       type="email"
                                       class="field-input"
                                       placeholder="tucorreo@ejemplo.com"
                                       asp-for="Correo"
                                       autocomplete="email"
                                       inputmode="email">
                            </div>
                        </div>

                        <div class="field-group">
                            <label class="field-label" for="Clave">Contraseña</label>
                            <div class="field-wrap">
                                <i class="fas fa-lock field-icon"></i>
                                <input id="Clave"
                                       type="password"
                                       class="field-input"
                                       placeholder="••••••••"
                                       asp-for="Clave"
                                       autocomplete="current-password">
                            </div>
                        </div>

                        <div class="check-group">
                            <input type="checkbox" id="chkMantenerSesion" asp-for="MantenerSesion">
                            <label for="chkMantenerSesion">Mantener sesión iniciada</label>
                        </div>

                        @if (ViewData["Mensaje"] != null)
                        {
                            <div class="alert-danger" role="alert">
                                <i class="fas fa-exclamation-circle"></i>
                                <span>@ViewData["Mensaje"]</span>
                            </div>
                        }

                        <button type="submit" class="btn-submit">
                            Ingresar
                        </button>

                    </form>

                    <div class="divider">o</div>

                    <div class="links-area">
                        <a class="link-item" href="@Url.Action("RestablecerClave","Acceso")">
                            ¿Olvidó su contraseña?
                        </a>
                        <a class="link-register" href="@Url.Action("Registrarse","Acceso")">
                            Crear una cuenta
                        </a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</body>

</html> *@


