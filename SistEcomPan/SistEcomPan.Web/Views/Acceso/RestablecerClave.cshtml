@model SistEcomPan.Web.Models.ViewModels.VMUsuarioLogin;

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ES">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Mi Tienda - Restablecer Clave</title>

    <link href="~/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">

    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --brand: #1a56db;
            --brand-dark: #1340b0;
            --border: #e5e7eb;
            --danger: #ef4444;
            --success: #10b981;
        }

        html, body {
            min-height: 100vh;
            font-family: 'DM Sans', sans-serif;
            background: linear-gradient(135deg, #1a56db 0%, #0f3a96 50%, #071d6a 100%);
        }

        .page-shell {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
        }

        .card {
            width: 100%;
            max-width: 400px;
            background: #fff;
            border-radius: 18px;
            box-shadow: 0 24px 64px rgba(0,0,0,.18);
            overflow: hidden;
            animation: fade .4s ease;
        }

        @@keyframes fade {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .header {
            text-align: center;
            padding: 30px 20px 15px;
            border-bottom: 1px solid var(--border);
        }

        .header h1 {
            font-size: 1.3rem;
            margin-bottom: 5px;
        }

        .header p {
            font-size: .85rem;
            color: #6b7280;
        }

        .form-body {
            padding: 25px;
        }

        .field {
            margin-bottom: 15px;
        }

        .label {
            font-size: .75rem;
            margin-bottom: 5px;
            display: block;
        }

        .input-wrap {
            position: relative;
        }

        .input-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #9ca3af;
        }

        .input {
            width: 100%;
            padding: 12px 12px 12px 35px;
            border-radius: 10px;
            border: 1px solid var(--border);
            background: #f9fafb;
        }

        .input:focus {
            border-color: var(--brand);
            outline: none;
            background: #fff;
        }

        .alert {
            border-radius: 8px;
            padding: 10px;
            font-size: .85rem;
            margin-bottom: 10px;
        }

        .alert-success {
            background: #ecfdf5;
            color: var(--success);
        }

        .alert-danger {
            background: #fee2e2;
            color: var(--danger);
        }

        .btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #1a56db, #1340b0);
            color: #fff;
            border: none;
            border-radius: 10px;
            cursor: pointer;
        }

        .btn:hover {
            opacity: .9;
        }

        .links {
            text-align: center;
            margin-top: 10px;
        }

        .links a {
            font-size: .85rem;
            color: var(--brand);
        }
    </style>
</head>

<body>

<div class="page-shell">

    <div class="card">

        <div class="header">
            <h1>¿Olvidó su contraseña?</h1>
            <p>Ingrese su correo para restablecerla</p>
        </div>

        <div class="form-body">

            <form asp-controller="Acceso" asp-action="ResetClave" method="post">

                <div class="field">
                    <label class="label">Correo electrónico</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" class="input" asp-for="Correo" placeholder="tucorreo@ejemplo.com">
                    </div>
                </div>

                @if (ViewData["Mensaje"] != null)
                {
                    <div class="alert alert-success">
                        @ViewData["Mensaje"]
                    </div>
                }

                @if (ViewData["MensajeError"] != null)
                {
                    <div class="alert alert-danger">
                        @ViewData["MensajeError"]
                    </div>
                }

                <button type="submit" class="btn">
                    Restablecer contraseña
                </button>

            </form>

            <div class="links">
                <a href="@Url.Action("Login","Acceso")">Volver al login</a>
            </div>

        </div>

    </div>

</div>

</body>
</html>

